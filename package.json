  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250204.0",
    "@opennextjs/cloudflare": "0.5.3",
    "@types/node": "22.9.1",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "8.56.0",
    "eslint-config-next": "14.2.5",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "wrangler": "3.107.3"
  },
  "scripts": {
    "build": "next build",
    "cf:build:raw": "opennextjs-cloudflare",
    "cf:build": "node scripts/run-with-env.mjs .env.production.secrets npm run cf:build:raw",
    "cf:check:raw": "opennextjs-cloudflare && tsc && wrangler deploy --dry-run",
    "cf:check": "node scripts/run-with-env.mjs .env.production.secrets npm run cf:check:raw",
    "check": "npm run cf:check",
    "cf:preview:raw": "opennextjs-cloudflare && wrangler dev",
    "cf:preview": "node scripts/run-with-env.mjs .env.production.secrets npm run cf:preview:raw",
    "preview": "npm run cf:preview",
    "cf:deploy:raw": "opennextjs-cloudflare && wrangler deploy",
    "cf:deploy": "node scripts/run-with-env.mjs .env.production.secrets npm run cf:deploy:raw",
    "deploy": "npm run cf:deploy",
    "cf:secrets:bulk": "npx wrangler secret bulk .env.production.secrets",
    "cf:secrets:sync": "node scripts/cf-secrets-sync.mjs",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv env.d.ts",
    "supabase:status": "node scripts/supabase-status.mjs",
    "supabase:link": "node scripts/supabase-link.mjs",
    "supabase:pull": "node scripts/supabase-pull.mjs",
    "supabase:dry-run": "node scripts/supabase-push.mjs --dry-run",
    "supabase:push": "node scripts/supabase-push.mjs",
    "dev": "dotenv -e .env.development next dev",
    "lint": "next lint",
    "start": "next start",
    "types": "npm run cf:typegen"
  }
}
